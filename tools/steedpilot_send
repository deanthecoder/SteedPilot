#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

mkdir -p build/tools
mkdir -p build/tools/SteedPilotSender.app/Contents/MacOS

swiftc \
  -Xlinker -sectcreate \
  -Xlinker __TEXT \
  -Xlinker __info_plist \
  -Xlinker tools/SteedPilotSenderInfo.plist \
  tools/steedpilot_send.swift \
  -o build/tools/SteedPilotSender.app/Contents/MacOS/SteedPilotSender

cp tools/SteedPilotSenderInfo.plist build/tools/SteedPilotSender.app/Contents/Info.plist
codesign --force --deep --sign - --entitlements tools/SteedPilotSender.entitlements build/tools/SteedPilotSender.app >/dev/null

exec build/tools/SteedPilotSender.app/Contents/MacOS/SteedPilotSender "$@"
