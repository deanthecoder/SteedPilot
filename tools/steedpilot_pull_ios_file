set -euo pipefail

device="${1:-Dean’s iPhone 17}"
source_file="${2:-SteedPilotRouteAudit.md}"
destination="${3:-/tmp/${source_file}}"

rm -f "${destination}"
xcrun devicectl device copy from \
    --device "${device}" \
    --domain-type appDataContainer \
    --domain-identifier com.deanthecoder.SteedPilot \
    --source "Documents/${source_file}" \
    --destination "${destination}"

cat "${destination}"
